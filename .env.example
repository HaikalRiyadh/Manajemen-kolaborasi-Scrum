# ====================================================
# Environment Variables - Scrum Management App
# ====================================================
# Copy this file to .env and edit the values
#   cp .env.example .env
# ====================================================

# ── Database ──────────────────────────────────────────
DB_ROOT_PASSWORD=scrumapp123
DB_NAME=lib_scrum_app
DB_USER=scrum_user
DB_PASSWORD=scrum_pass
DB_PORT=3306

# ── API ───────────────────────────────────────────────
API_PORT=8080

# ── phpMyAdmin (dev only) ─────────────────────────────
PMA_PORT=8081

# ── Railway / Cloud Deployment ────────────────────────
# Pada saat deploy ke Railway atau cloud PaaS, set variabel
# berikut sesuai konfigurasi database cloud:
# RAILWAY_MYSQL_URL=mysql://user:pass@host:port/dbname
